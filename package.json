{
  "name": "blog",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "rimraf dist && docker compose -f kroki/docker-compose.yml up -d && astro build && docker compose -f kroki/docker-compose.yml down",
    "check": "astro check",
    "dev": "concurrently \"docker compose -f kroki/docker-compose.yml up\" \"astro dev --host\"",
    "e2e": "rimraf test-results && playwright test",
    "e2e:update": "playwright test --update-snapshots",
    "preview": "astro --host preview",
    "start": "pnpm build && serve dist",
    "test": "vitest"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/markdown-remark": "^6.3.1",
    "@astrojs/mdx": "^4.2.3",
    "@astrojs/sitemap": "^3.3.0",
    "@astrojs/svelte": "^7.0.9",
    "@playwright/test": "^1.50.1",
    "astro": "^5.6.1",
    "astro-og-canvas": "^0.5.6",
    "canvaskit-wasm": "^0.39.1",
    "lodash-es": "^4.17.21",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-external-links": "^3.0.0",
    "rehype-rewrite": "^4.0.2",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-kroki": "^0.3.7",
    "remark-merge-data": "^1.0.13",
    "remark-smartypants": "^2.1.0",
    "rimraf": "^6.0.1",
    "sass": "^1.85.1",
    "svelte": "^5.20.5",
    "typescript": "^5.8.2",
    "vega-lite": "^5.23.0",
    "vitest": "^3.0.7"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.13.8",
    "concurrently": "^9.1.2",
    "serve": "^14.2.4",
    "tsx": "^4.19.3"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "sharp"
    ]
  }
}
